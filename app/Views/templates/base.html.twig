<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}E-book - Sistema de Cadastro{% endblock %}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:wght@600;700&family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="{{ asset('assets/js/tailwind.config.js') }}"></script>
</head>
<body class="min-h-screen bg-clay text-ink antialiased">
    <div class="flex min-h-screen flex-col">
        <header class="border-b border-secondary/15 bg-white">
            <div class="mx-auto flex max-w-6xl flex-col gap-4 px-4 py-4 sm:px-6 lg:flex-row lg:items-center lg:justify-between lg:px-8">
                <a href="/" class="inline-flex items-center gap-3 text-ink">
                    <span class="flex h-12 w-12 items-center justify-center rounded-2xl bg-[#d9480f] text-white">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                        </svg>
                    </span>
                    <span class="block font-display text-3xl leading-none tracking-tight text-ink">E-book</span>
                </a>

                <nav class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
                    <a href="/" class="inline-flex items-center justify-center rounded-full border border-secondary/20 px-4 py-2 text-sm font-semibold
                                        text-secondary transition hover:border-[#d9480f] hover:text-[#d9480f]">
                        Catálogo
                    </a>
                    {# <a href="/autores/cadastrar" class="inline-flex items-center justify-center rounded-full border border-secondary/20 px-4 py-2 text-sm font-semibold text-secondary transition hover:border-[#d9480f] hover:text-[#d9480f]">
                        Cadastrar autor
                    </a>
                    <a href="/assuntos/cadastrar" class="inline-flex items-center justify-center rounded-full border border-secondary/20 px-4 py-2 text-sm font-semibold text-secondary transition hover:border-[#d9480f] hover:text-[#d9480f]">
                        Cadastrar assunto
                    </a>
                    <a href="/livros/cadastrar" class="inline-flex items-center justify-center rounded-full bg-[#d9480f] px-4 py-2 text-sm font-semibold text-white transition hover:bg-[#b93e0d]">
                        Cadastrar livro
                    </a> #}
                </nav>
            </div>
        </header>

        <main class="mx-auto w-full max-w-6xl flex-1 bg-clay px-4 py-6 sm:px-6 sm:py-8 lg:px-8">
            {% block content %}{% endblock %}
        </main>

        <footer class="mt-auto border-t border-secondary/15 bg-white py-6">
            <div class="mx-auto flex max-w-6xl flex-col gap-2 px-4 text-sm text-secondary sm:px-6 lg:flex-row lg:items-center lg:justify-between lg:px-8">
                <p>&copy; {{ "now"|date("Y") }} E-book. Sistema de cadastro de livros.</p>
            </div>
        </footer>
    </div>
</body>
</html>
