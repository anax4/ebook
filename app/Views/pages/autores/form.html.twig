{% extends "templates/base.html.twig" %}

{% block title %}{{ title }} - E-book{% endblock %}

{% block content %}
<section class="mx-auto max-w-4xl animate-rise rounded-[2rem] border border-secondary/15 bg-sand/95 shadow-panel">
    <div class="border-b border-secondary/10 px-5 py-5 sm:px-8">
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-secondary">Formulário</p>
        <h1 class="mt-2 font-display text-3xl text-ink sm:text-4xl">{{ title }}</h1>
    </div>

    {% if errors is defined and errors is not empty %}
    <div class="mx-5 mt-5 sm:mx-8">
        {% include 'components/feedback-card.html.twig' with {
            variant: 'error',
            title: 'Não foi possível salvar',
            items: errors
        } only %}
    </div>
    {% endif %}

    <form
        method="POST"
        action="{{ action }}"
        class="grid gap-5 p-5 sm:p-8"
    >
        <div>
            <label for="nome" class="mb-2 block text-sm font-semibold text-ink">
                Nome do autor <span class="text-danger">*</span>
            </label>
            <input
                type="text"
                id="nome"
                name="nome"
                value="{{ autor.nome|default('') }}"
                maxlength="40"
                required
                class="w-full rounded-2xl border border-secondary/20 bg-white px-4 py-3 text-ink outline-none transition placeholder:text-secondary/55 focus:border-primary focus:ring-4 focus:ring-primary/10"
                placeholder="Digite o nome do autor"
            >
        </div>

        <div class="flex flex-col gap-3 sm:flex-row">
            <button type="submit" class="inline-flex flex-1 items-center justify-center rounded-full bg-[#b93e0d] px-6 py-3 text-sm font-semibold text-white transition hover:bg-[#9c330b]">
                {% if autor and autor.id is defined %}Atualizar autor{% else %}Salvar autor{% endif %}
            </button>
            <a href="/" class="inline-flex flex-1 items-center justify-center rounded-full border border-secondary/20 bg-sand/60 px-6 py-3 text-sm font-semibold text-secondary transition hover:border-[#d9480f] hover:bg-sand hover:text-[#d9480f]">
                Voltar
            </a>
        </div>
    </form>

    <div class="border-t border-secondary/10 px-5 py-5 sm:px-8">
        <h2 class="font-display text-2xl text-ink">Autores cadastrados</h2>
        {% if autores is empty %}
        <p class="mt-2 text-sm text-secondary">Nenhum autor cadastrado ainda.</p>
        {% else %}
        <ul class="mt-4 grid gap-3">
            {% for item in autores %}
            {% set totalLivrosRelacionados = item.total_livros_relacionados|default(0) %}
            <li class="flex flex-col gap-3 rounded-2xl border border-primary/15 bg-white/70 px-4 py-4 sm:flex-row sm:items-center sm:justify-between">
                <div>
                    <p class="text-sm font-medium text-ink">{{ item.nome }}</p>
                    {% if totalLivrosRelacionados > 0 %}
                    <p class="mt-1 text-xs text-secondary">
                        Vinculado a {{ totalLivrosRelacionados }} livro{% if totalLivrosRelacionados > 1 %}s{% endif %}.
                    </p>
                    {% endif %}
                </div>
                <div class="flex flex-col gap-3 sm:flex-row">
                    <a href="/autores/editar/{{ item.id }}" class="inline-flex items-center justify-center rounded-full bg-[#b93e0d] px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-[#9c330b]">
                        Editar
                    </a>
                    {% if totalLivrosRelacionados > 0 %}
                    <button
                        type="button"
                        disabled
                        title="Este autor possui livros relacionados e não pode ser excluído."
                        class="inline-flex w-full cursor-not-allowed items-center justify-center rounded-full border border-secondary/15 bg-secondary/10 px-5 py-2.5 text-sm font-semibold text-secondary/70 opacity-80"
                    >
                        Excluir
                    </button>
                    {% else %}
                    <form action="/autores/excluir/{{ item.id }}" method="POST" data-delete-confirmable data-delete-message="Tem certeza que deseja excluir este autor?">
                        <button type="button" data-delete-toggle class="inline-flex w-full items-center justify-center rounded-full border border-danger/20 bg-danger/5 px-5 py-2.5 text-sm font-semibold text-danger transition hover:bg-danger hover:text-white">
                            Excluir
                        </button>
                    </form>
                    {% endif %}
                </div>
            </li>
            {% endfor %}
        </ul>
        {% endif %}
    </div>
</section>
{% endblock %}
