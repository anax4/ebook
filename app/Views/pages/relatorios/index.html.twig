{% extends "templates/base.html.twig" %}

{% block title %}{{ title }} - E-book{% endblock %}

{% block content %}
<section class="mb-6 animate-rise rounded-[2rem] border border-secondary/15 bg-white shadow-panel">
    <div class="border-b border-secondary/10 px-5 py-5 sm:px-8">
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-secondary">Relatório</p>
        <h1 class="mt-2 font-display text-3xl text-ink sm:text-4xl">{{ title }}</h1>
    </div>

    <div class="grid gap-4 border-b border-secondary/10 px-5 py-5 sm:grid-cols-2 sm:px-8">
        <article class="rounded-[1.5rem] border border-secondary/15 bg-sand/80 p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-secondary">Autores</p>
            <p class="mt-2 font-display text-3xl text-ink">{{ totais.autores }}</p>
        </article>

        <article class="rounded-[1.5rem] border border-secondary/15 bg-sand/80 p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-secondary">Livros</p>
            <p class="mt-2 font-display text-3xl text-ink">{{ totais.livros }}</p>
        </article>
    </div>

    {% if grupos is empty %}
    <div class="p-8 text-center sm:p-12">
        <p class="text-lg font-medium text-ink">Nenhum registro disponível para o relatório.</p>
    </div>
    {% else %}
    <div class="grid gap-6 p-5 sm:p-8">
        {% for grupo in grupos %}
        <article class="rounded-[1.75rem] border border-secondary/15 bg-sand/55 p-5 shadow-sm">
            <div class="flex flex-col gap-3 border-b border-secondary/10 pb-4 sm:flex-row sm:items-end sm:justify-between">
                <div>
                    <p class="text-xs font-semibold uppercase tracking-[0.22em] text-secondary">Autor</p>
                    <h2 class="mt-2 font-display text-2xl text-ink">{{ grupo.autor_nome }}</h2>
                </div>
                <p class="text-sm font-medium text-secondary">{{ grupo.livros|length }} livro{% if grupo.livros|length > 1 %}s{% endif %} no grupo</p>
            </div>

            <ul class="mt-5 grid gap-4">
                {% for livro in grupo.livros %}
                <li class="rounded-[1.5rem] border border-primary/10 bg-white p-5">
                    <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                        <div>
                            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-secondary">Livro #{{ livro.livro_id }}</p>
                            <h3 class="mt-2 font-display text-2xl text-ink">{{ livro.titulo }}</h3>
                            <p class="mt-2 text-sm text-secondary">
                                {{ livro.editora }} • {{ livro.edicao }}ª edição • {{ livro.anoPublicacao }}
                            </p>
                            <p class="mt-2 text-sm font-semibold text-primary">R$ {{ livro.valor|number_format(2, ',', '.') }}</p>
                        </div>

                        <a href="/livros/editar/{{ livro.livro_id }}" class="inline-flex items-center justify-center rounded-full bg-[#b93e0d] px-5 py-3 text-sm font-semibold text-white transition hover:bg-[#9c330b]">
                            Abrir cadastro
                        </a>
                    </div>

                    <dl class="mt-5 grid gap-4 sm:grid-cols-2">
                        <div class="rounded-2xl border border-secondary/10 bg-ember/35 p-4">
                            <dt class="text-xs font-semibold uppercase tracking-[0.18em] text-secondary">Autores do livro</dt>
                            <dd class="mt-2 text-sm text-ink">{{ livro.autores_livro }}</dd>
                        </div>
                        <div class="rounded-2xl border border-secondary/10 bg-ember/35 p-4">
                            <dt class="text-xs font-semibold uppercase tracking-[0.18em] text-secondary">Assuntos do livro</dt>
                            <dd class="mt-2 text-sm text-ink">
                                {% if livro.assuntos_livro %}
                                    {{ livro.assuntos_livro }}
                                {% else %}
                                    Nenhum assunto vinculado.
                                {% endif %}
                            </dd>
                        </div>
                    </dl>
                </li>
                {% endfor %}
            </ul>
        </article>
        {% endfor %}
    </div>
    {% endif %}
</section>
{% endblock %}
