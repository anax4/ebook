{% extends "templates/base.html.twig" %}

{% block title %}{{ title }} - E-book{% endblock %}

{% block content %}
<section class="mb-6 rounded-3xl border border-secondary/15 bg-white shadow-panel">
    <div class="border-b border-secondary/10 px-5 py-5 sm:px-8">
        <h1 class="font-display text-3xl text-ink sm:text-4xl">{{ title }}</h1>
    </div>

    <div class="border-b border-secondary/10 px-5 py-5 sm:px-8">
        <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
            <label class="block">
                <span class="mb-2 block text-sm font-medium text-secondary">Busca</span>
                <input
                    id="report-search"
                    type="text"
                    class="w-full rounded-2xl border border-secondary/20 bg-white px-4 py-3 text-sm text-ink outline-none transition placeholder:text-secondary/55 focus:border-primary focus:ring-4 focus:ring-primary/10"
                    placeholder="Título, autor ou assunto"
                >
                <span id="report-search-error" class="mt-2 hidden text-sm text-danger"></span>
            </label>

            <label class="block">
                <span class="mb-2 block text-sm font-medium text-secondary">Autor</span>
                <select id="report-author" class="w-full rounded-2xl border border-secondary/20 bg-white px-4 py-3 text-sm text-ink outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/10">
                    <option value="">Todos os autores</option>
                </select>
                <span id="report-author-error" class="mt-2 hidden text-sm text-danger"></span>
            </label>

            <label class="block">
                <span class="mb-2 block text-sm font-medium text-secondary">Ano</span>
                <select id="report-year" class="w-full rounded-2xl border border-secondary/20 bg-white px-4 py-3 text-sm text-ink outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/10">
                    <option value="">Todos os anos</option>
                </select>
                <span id="report-year-error" class="mt-2 hidden text-sm text-danger"></span>
            </label>

            <label class="block">
                <span class="mb-2 block text-sm font-medium text-secondary">Ordenação</span>
                <select id="report-sort" class="w-full rounded-2xl border border-secondary/20 bg-white px-4 py-3 text-sm text-ink outline-none transition focus:border-primary focus:ring-4 focus:ring-primary/10">
                    <option value="title">Título A-Z</option>
                    <option value="year">Ano mais recente</option>
                    <option value="value">Maior valor</option>
                </select>
                <span id="report-sort-error" class="mt-2 hidden text-sm text-danger"></span>
            </label>
        </div>

        <div class="mt-4 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
            <button id="report-clear" type="button" class="inline-flex items-center justify-center rounded-full border border-secondary/20 bg-white px-5 py-3 text-sm font-semibold text-secondary transition hover:border-primary hover:text-primary">
                Limpar filtros
            </button>
            <button id="report-reload" type="button" class="inline-flex items-center justify-center rounded-full border border-secondary/20 bg-white px-5 py-3 text-sm font-semibold text-secondary transition hover:border-primary hover:text-primary">
                Atualizar relatório
            </button>
            <button id="report-export" type="button" class="inline-flex items-center justify-center rounded-full bg-primary px-5 py-3 text-sm font-semibold text-white transition hover:bg-primary-hover">
                Exportar CSV
            </button>
            <button id="report-print" type="button" class="inline-flex items-center justify-center rounded-full bg-primary px-5 py-3 text-sm font-semibold text-white transition hover:bg-primary-hover">
                Imprimir
            </button>
        </div>
    </div>

    <div class="p-5 sm:p-8">
        <div class="mb-4 text-sm text-secondary">
            <span id="report-status">Aguardando carregamento do relatório.</span>
            <span class="mx-2">|</span>
            <span>Total de autores: <strong id="report-total">0</strong></span>
        </div>
        <div id="report-error" class="hidden rounded-[1.5rem] border border-danger/20 bg-danger/5 p-5 text-sm text-danger"></div>
        <div id="report-empty" class="hidden rounded-[1.5rem] border border-secondary/15 bg-sand/55 p-5 text-sm text-secondary">
            Nenhum resultado encontrado para os filtros informados.
        </div>
        <div id="report-loading" class="hidden rounded-[1.5rem] border border-secondary/15 bg-sand/55 p-5 text-sm text-secondary">
            Carregando relatório...
        </div>
        <div id="report-groups" class="space-y-6"></div>
    </div>
</section>
{% endblock %}

{% block scripts %}
<script type="module" src="{{ asset('assets/js/report-viewer.js') }}"></script>
{% endblock %}
